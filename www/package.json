{
  "name": "luke-doku",
  "version": "0.1.0",
  "description": "The best Sudoku on the web",
  "type": "module",
  "scripts": {
    "build:wasm": "wasm-pack build ../crate --target web --out-name luke_doku",
    "build": "npm run build:wasm && tsc --noEmit && vite build",
    "start": "http-server dist",
    "dev": "npm run build:wasm && vite",
    "test-setup": "npm run build:wasm && npm install luke-doku-rust",
    "test": "web-test-runner"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leadpipe/luke-doku.git"
  },
  "keywords": [
    "sudoku"
  ],
  "author": "Luke Blanshard <luke.blanshard@gmail.com>",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/leadpipe/luke-doku/issues"
  },
  "homepage": "https://github.com/leadpipe/luke-doku",
  "dependencies": {
    "@fontsource-utils/scss": "^0.2.2",
    "@fontsource/lumanosimo": "5.2.7",
    "@fontsource/material-icons": "5.2.7",
    "@fontsource/merriweather-sans": "5.2.7",
    "@fontsource/prompt": "5.2.8",
    "idb": "^8.0.0",
    "lit": "3.3.2",
    "luke-doku-rust": "file:../crate/pkg"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.0",
    "@babel/preset-typescript": "7.28.5",
    "@esm-bundle/chai": "^4.3.4-fix.0",
    "@rollup/plugin-wasm": "^6.2.2",
    "@types/chai": "^5.2.3",
    "@types/gtag.js": "0.0.20",
    "@types/mocha": "^10.0.10",
    "@types/sinon": "^21.0.0",
    "@web/dev-server-esbuild": "^1.0.1",
    "@web/dev-server-rollup": "^0.6.4",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-playwright": "^0.11.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "file-loader": "^6.2.0",
    "http-server": "^14.1.1",
    "lit-css-loader": "4.0.1",
    "node-http-server": "8.1.6",
    "prettier-plugin-organize-imports": "^4.1.0",
    "sass": "1.98.0",
    "sinon": "^21.0.3",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-checker": "^0.12.0",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0"
  }
}
